# Copy to .env.local: cp .env.example .env.local
# If you want docker compose to pick up these same values, copy it to .env too.

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
# Keep DATABASE_URL in sync with the POSTGRES_* values below.
POSTGRES_PORT=5433
POSTGRES_DB=public_site_with_cms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/public_site_with_cms
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Payload
PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Scheduled publishing worker
SCHEDULED_PUBLISH_INTERVAL_MS=60000
SCHEDULED_PUBLISH_BATCH_SIZE=100

# Database backups
BACKUP_DIR=/backups
BACKUP_PREFIX=public-site-with-cms
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_COUNT=7
