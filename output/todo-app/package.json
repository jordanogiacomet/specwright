{
  "name": "todo-app",
  "version": "0.1.0",
  "private": true,
  "description": "todo-app",
  "scripts": {
    "dev": "next dev",
    "dev:api": "node --env-file=.env.local --import tsx src/server.ts",
    "dev:worker": "node --env-file=.env.local --import tsx src/jobs/index.ts",
    "build": "next build",
    "start": "next start",
    "start:api": "node --env-file=.env.local --import tsx src/server.ts",
    "start:worker": "node --env-file=.env.local --import tsx src/jobs/index.ts",
    "db:migrate:create": "node ./src/lib/create-migration.mjs",
    "db:migrate": "node-pg-migrate up --migrations-dir src/models/migrations --envPath .env.local",
    "db:migrate:status": "node-pg-migrate up --migrations-dir src/models/migrations --envPath .env.local --dry-run",
    "lint": "eslint . --max-warnings=0",
    "test": "echo \"No tests configured yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2",
    "dotenv": "^17.3.1",
    "express": "^4",
    "helmet": "^7",
    "next": "^15",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/node": "^22",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
