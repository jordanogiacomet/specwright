# Environment variables for Editorial E2E Test
# Copy to .env.local: cp .env.example .env.local

DATABASE_URI=postgresql://postgres:postgres@localhost:5433/editorial_e2e_test
POSTGRES_PORT=5433  # Change if 5433 is also in use

PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-random-secret
