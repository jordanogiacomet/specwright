# Environment variables for Editorial E2E Test
# .env.local is auto-generated — edit it for local overrides

DATABASE_URI=postgresql://postgres:postgres@localhost:5438/editorial_e2e_test
POSTGRES_PORT=5438  # Unique per project — change if 5438 is in use

PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server
PORT=3000
NODE_ENV=development
