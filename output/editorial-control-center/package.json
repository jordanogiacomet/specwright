{
  "name": "editorial-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Editorial Control Center",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:types": "payload --disable-transpile generate:types",
    "db:migrate": "node ./scripts/payload-migrations.mjs migrate",
    "db:migrate:create": "node ./scripts/payload-migrations.mjs create",
    "db:migrate:status": "node ./scripts/payload-migrations.mjs status"
  },
  "dependencies": {
    "next": "15.4.11",
    "react": "^19",
    "react-dom": "^19",
    "@payloadcms/next": "^3",
    "@payloadcms/richtext-lexical": "^3",
    "@payloadcms/db-postgres": "^3",
    "payload": "^3",
    "graphql": "^16",
    "pg": "^8",
    "sharp": "^0.33"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "@eslint/eslintrc": "^3",
    "eslint-config-next": "15.4.11",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "@tailwindcss/postcss": "^4",
    "vitest": "^3.1.1"
  }
}
