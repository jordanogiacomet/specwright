{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SemanticSpec",
  "type": "object",
  "required": [
    "product_name",
    "project_slug",
    "archetype",
    "architecture",
    "stories"
  ],

  "properties": {

    "product_name": {
      "type": "string",
      "minLength": 3
    },

    "project_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },

    "archetype": {
      "type": "string",
      "enum": [
        "next-payload-postgres"
      ]
    },

    "summary": {
      "type": "string"
    },

    "architecture": {
      "type": "object",
      "required": [
        "frontend",
        "cms",
        "database",
        "deployment"
      ],
      "properties": {

        "frontend": {
          "type": "string"
        },

        "cms": {
          "type": "string"
        },

        "database": {
          "type": "string"
        },

        "deployment": {
          "type": "string"
        }

      }
    },

    "stories": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/story"
      }
    }

  },

  "definitions": {

    "story": {
      "type": "object",
      "required": [
        "story_id",
        "title",
        "description"
      ],

      "properties": {

        "story_id": {
          "type": "string",
          "pattern": "^STORY-[0-9]{3}$"
        },

        "title": {
          "type": "string"
        },

        "description": {
          "type": "string"
        },

        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }

      }
    }

  }
}